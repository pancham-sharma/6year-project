{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://donation-admin-panel.onrender.com/api/$1" },
    { "source": "/media/(.*)", "destination": "https://donation-admin-panel.onrender.com/media/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
